# ── Directory contents (keep dirs, ignore everything inside) ──
books/**
!books/.gitkeep

data/**
!data/.gitkeep

scripts/**
!scripts/.gitkeep
!scripts/extract_pdf_text.py
!scripts/extract_wod_pdfs.py
!scripts/generate_image.py

RPG/**
!RPG/.gitkeep

# ── WoD source PDFs ──
wod_20_books/

# ── Game-specific skills (generated by rpg-ingest, not tracked) ──
.claude/commands/*-character.md
.claude/commands/*-npc.md
.claude/commands/*-combat.md
.claude/commands/*-advance.md

# ── Claude internal project state (memory, plans, sessions) ──
.claude/projects/
.claude/plans/
.claude/settings.local.json

# ── Python cache ──
__pycache__/
*.pyc
*.pyo

# ── Backups / OS files ──
*.bak
.DS_Store
Thumbs.db
